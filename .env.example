# Infrastructure-only configuration (REQ-009).
# Everything trading-related (API keys, strategies, risk) is configured from the
# frontend and stored in the database, NOT here.

# PostgreSQL (async DSN used by the app; Alembic derives the sync DSN from it).
DATABASE_URL=postgresql+asyncpg://bitunix:bitunix@postgres:5432/bitunix

# Kafka / Redpanda bootstrap servers.
KAFKA_BOOTSTRAP_SERVERS=redpanda:9092

# Fernet key (urlsafe base64, 32 bytes) used to encrypt API secrets at rest.
# Generate one with:  python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# ngrok token for exposing local Postgres (optional).
# Create one at https://dashboard.ngrok.com/get-started/your-authtoken
# After `docker compose up`, inspect the public TCP endpoint via:
#   curl http://localhost:4040/api/tunnels
NGROK_AUTHTOKEN=

# Operational toggles.
APP_ENV=development
LOG_LEVEL=INFO
LOG_JSON=false
